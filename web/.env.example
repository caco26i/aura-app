# Copy to `.env.local` for development.

# Google OAuth (optional — app runs in stub mode without it)
# VITE_GOOGLE_CLIENT_ID=

# Authoritative API (optional — without token, SOS/journey calls use local mocks)
# Same-origin: set token only; Vite proxies /v1 and /health to local server (see vite.config.ts).
VITE_AURA_API_TOKEN=
# VITE_AURA_API_URL=

# Override proxy target (default http://127.0.0.1:8787) — shell only, not VITE_
# VITE_AURA_DEV_API_PROXY=http://127.0.0.1:8787

# Telemetry (optional)
# Same-origin dev stub: `npm run dev` serves POST /ingest/aura → 204 unless you set the proxy below.
# VITE_AURA_TELEMETRY_ENDPOINT=/ingest/aura
# Forward /ingest/aura to a local collector (shell only, not VITE_)
# VITE_AURA_DEV_TELEMETRY_PROXY=http://127.0.0.1:9999
# Or use a full staging/collector URL instead of /ingest/aura.
# VITE_AURA_TELEMETRY_ENDPOINT=https://collector.example/ingest/aura
# Console metrics helper: `true` or `1`
# VITE_AURA_TELEMETRY_DEBUG=1
