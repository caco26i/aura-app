# Aura — root Compose environment (example only)
#
# This file is NOT loaded automatically. Copy to `.env` in the repo root and replace
# every placeholder before running Docker Compose. Never commit a filled `.env`.
#
# Default stack:
#   docker compose up --build
#
# JWT + BFF stack (no static API token in the web image):
#   docker compose -f docker-compose.yml -f docker-compose.bff.yml up --build
#
# Runbook: web/docs/DEPLOY.md · BFF env details: server/bff/README.md

# --- Ports (optional; Compose defaults shown in docker-compose.yml) ---
# WEB_PORT=8080
# API_PORT=8787

# =============================================================================
# Static-bearer stack (docker-compose.yml only)
# =============================================================================
# Required for the default compose file: same value is passed into the web image
# as VITE_AURA_API_TOKEN at build time unless you override VITE_AURA_API_TOKEN.
# AURA_API_BEARER_TOKEN=change-me-long-random-token

# Optional explicit web build token (defaults to AURA_API_BEARER_TOKEN when unset)
# VITE_AURA_API_TOKEN=

# =============================================================================
# BFF + JWT stack (docker-compose.yml + docker-compose.bff.yml)
# =============================================================================
# Required when using docker-compose.bff.yml (see docker-compose.bff.yml header).
# AURA_API_BFF_JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# AURA_BFF_SESSION_SECRET=0123456789abcdef0123456789abcdef
# Must match the web build — compose sets AURA_BFF_GOOGLE_CLIENT_ID from this key.
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Credentialed CORS when the SPA origin differs from the BFF (comma-separated)
# AURA_BFF_CORS_ORIGIN=http://127.0.0.1:8080

# For the BFF path, leave bearer empty (compose override clears it on aura-api)
# AURA_API_BEARER_TOKEN=

# =============================================================================
# API deploy metadata (optional — echoed by GET /health and GET /ready)
# =============================================================================
# AURA_API_DEPLOY_VERSION=v1.2.3
# AURA_API_GIT_SHA=abcdef0123456789abcdef0123456789abcdef01

# =============================================================================
# Web image build args (read from this `.env` by root compose)
# =============================================================================
# VITE_AURA_API_URL=
# VITE_AURA_TELEMETRY_ENDPOINT=
# VITE_AURA_TELEMETRY_DEBUG=

# =============================================================================
# Web container runtime (nginx telemetry proxy)
# =============================================================================
# AURA_TELEMETRY_PROXY_TARGET=https://collector.example/ingest/aura

# =============================================================================
# BFF rate limits (optional; BFF defaults are permissive for dev/CI)
# =============================================================================
# Tighten in staging/production — see server/bff/README.md.
# Example: 15-minute window, max 30 POST /auth/google attempts per IP (values in ms / count).
# AURA_BFF_RATE_LIMIT_AUTH_GOOGLE_WINDOW_MS=900000
# AURA_BFF_RATE_LIMIT_AUTH_GOOGLE_MAX=30
# AURA_BFF_RATE_LIMIT_SESSION_WINDOW_MS=
# AURA_BFF_RATE_LIMIT_SESSION_MAX=
# AURA_BFF_RATE_LIMIT_LOGOUT_WINDOW_MS=
# AURA_BFF_RATE_LIMIT_LOGOUT_MAX=
